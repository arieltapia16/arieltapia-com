# Plantilla de variables de entorno — copiá a .env.local y completá con valores reales.
# En producción (Vercel) se configuran desde Settings → Environment Variables.

# Resend — envío de emails del formulario de contacto
RESEND_API_KEY=

# PayPal (legacy — el flujo principal ahora es Whop pero las rutas siguen existiendo)
# https://developer.paypal.com/dashboard/applications/
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# Whop — plan_id del producto (dashboard.whop.com → Checkout links → tres puntos → Details → ID)
NEXT_PUBLIC_WHOP_PLAN_ID=plan_xxxxxxxxxxx

# Whop webhook — firma del endpoint /api/whop/webhook (manda el email de compra).
# Dashboard → Developer → Webhooks → crear endpoint con la URL del sitio
# (.../api/whop/webhook), habilitar el evento "payment.succeeded" y copiar el secret.
WHOP_WEBHOOK_SECRET=
# Opcional: solo si querés usar la API de Whop server-side (no requerido por el webhook).
WHOP_API_KEY=

# Meta Pixel — ID del pixel para tracking en /curso
NEXT_PUBLIC_META_PIXEL_ID=
